# Copy this file to .env and fill in any values you want to override.
# Defaults work out of the box with `make up`.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://pitwall:pitwall@localhost:5432/pitwall


# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── MLflow ────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5001

# ── Flask ─────────────────────────────────────────────────────────────────────
SECRET_KEY=dev-secret-key-change-in-production
DEBUG=true
TESTING=false

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000


# Cloudflare R2 (for telemetry artifacts)
TELEMETRY_STORAGE_MODE=files
TELEMETRY_ARTIFACT_BACKEND=r2
TELEMETRY_ARTIFACT_BUCKET=pitwall-telemetry
R2_ENDPOINT_URL=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=YOUR_ACCESS_KEY_ID
R2_SECRET_ACCESS_KEY=YOUR_SECRET_ACCESS_KEY

RACE_VECTOR_INDEX_DIR=./lancedb
RACE_VECTOR_TABLE=race_intelligence_events